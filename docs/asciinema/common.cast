[0.00, "o", "\u001b[H\u001b[2J\u001b[3J"]

[0.00, "o", "\u001b[38;5;220m"]
[0.00, "o", "# All tfctl commands have a common set of arguments.\r\n\r\n"]

[0.00, "o", "# Help is always available with --help.\r\n"]
[0.00, "o", "\u001b[38;5;33m~/iac> \u001b[33;5;33m"]
[3.00, "o", "t"]
[0.07, "o", "f"]
[0.07, "o", "c"]
[0.07, "o", "t"]
[0.07, "o", "l"]
[0.07, "o", " "]
[0.07, "o", "s"]
[0.07, "o", "q"]
[0.07, "o", " \u001b[32m"]
[0.07, "o", "-"]
[0.07, "o", "-"]
[0.07, "o", "h"]
[0.07, "o", "e"]
